{
  "manifest_version": 3,
  "name": "PassFF (self-hosted)",
  "version": "1.0.0",
  "description": "Access your zx2c4 pass password store from Chromium through the PassFF native messaging host.",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "clipboardWrite",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PassFF"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
